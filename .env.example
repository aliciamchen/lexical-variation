# Copy to .env and fill in values.
# .env is gitignored and will not be committed.

# Production Empirica server hostname (used by copy_tajriba.sh and docs)
EMPIRICA_SERVER=your-server.empirica.app

# Sentry DSN for client error reporting (used by experiment/client)
VITE_SENTRY_DSN=your-sentry-dsn

# Sentry organization slug (for dashboard URLs in docs)
SENTRY_ORG=your-sentry-org
